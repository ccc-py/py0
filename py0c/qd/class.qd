CLASS               Student                                 _               _                 ; class Student
FUNCTION            _                                       _               __init__          ; function __init__
ENTER_SCOPE         _                                       _               _               
PARAM               _                                       _               self            
PARAM               _                                       _               name            
PARAM               _                                       _               grades          
LOAD_NAME           name                                    _               t0                ; load name
LOAD_NAME           self                                    _               t1                ; load self
STORE_ATTR          t1                                      name            t0              
LOAD_NAME           grades                                  _               t2                ; load grades
LOAD_NAME           self                                    _               t3                ; load self
STORE_ATTR          t3                                      grades          t2              
EXIT_SCOPE          _                                       _               _               
FUNCTION_END        _                                       _               __init__        
FUNCTION            _                                       _               get_average       ; function get_average
ENTER_SCOPE         _                                       _               _               
PARAM               _                                       _               self            
LOAD_NAME           self                                    _               t4                ; load self
LOAD_ATTR           t4                                      grades          t5                ; getattr grades
NOT                 t5                                      _               t6              
BRANCH_IF_FALSE     t6                                      _               L_else0           ; if not test, go to else
LOAD_CONST          0                                       _               t7                ; load 0
RETURN              t7                                      _               _                 ; return value
JUMP                L_end1                                  _               _                 ; skip else
L_else0::
L_end1::
LOAD_NAME           sum                                     _               t8                ; load sum
LOAD_NAME           self                                    _               t9                ; load self
LOAD_ATTR           t9                                      grades          t10               ; getattr grades
ARG_PUSH            t10                                     0               _               
CALL                t8                                      1               t11             
LOAD_NAME           len                                     _               t12               ; load len
LOAD_NAME           self                                    _               t13               ; load self
LOAD_ATTR           t13                                     grades          t14               ; getattr grades
ARG_PUSH            t14                                     0               _               
CALL                t12                                     1               t15             
DIV                 t11                                     t15             t16             
RETURN              t16                                     _               _                 ; return value
EXIT_SCOPE          _                                       _               _               
FUNCTION_END        _                                       _               get_average     
FUNCTION            _                                       _               introduce         ; function introduce
ENTER_SCOPE         _                                       _               _               
PARAM               _                                       _               self            
LOAD_NAME           self                                    _               t17               ; load self
LOAD_ATTR           t17                                     get_average     t18               ; getattr get_average
CALL                t18                                     0               t19             
STORE               t19                                     _               avg               ; assign avg
LOAD_NAME           print                                   _               t20               ; load print
FSTRING_START       _                                       _               t21               ; f-string start
FSTRING_PART        '你好，我是 '                                _               _                 ; literal: 你好，我是 
LOAD_NAME           self                                    _               t22               ; load self
LOAD_ATTR           t22                                     name            t23               ; getattr name
FSTRING_PART        t23                                     _               _                 ; expr: t23
FSTRING_PART        '，我的平均成績是 '                             _               _                 ; literal: ，我的平均成績是 
LOAD_NAME           avg                                     _               t24               ; load avg
FSTRING_PART        t24                                     _               _                 ; expr: t24
FSTRING_PART        ' 分。'                                   _               _                 ; literal:  分。
FSTRING             _                                       _               t21               ; f-string end
ARG_PUSH            t21                                     0               _               
CALL                t20                                     1               t25             
EXIT_SCOPE          _                                       _               _               
FUNCTION_END        _                                       _               introduce       
CLASS_END           _                                       _               Student         
