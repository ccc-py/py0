LOAD_NAME           student_a                               _               t40               ; load student_a
LOAD_ATTR           t40                                     introduce       t41               ; getattr introduce
CALL                t41                                     0               t42             
LOAD_NAME           student_b                               _               t43               ; load student_b
LOAD_ATTR           t43                                     introduce       t44               ; getattr introduce
CALL                t44                                     0               t45             
LOAD_NAME           print                                   _               t46               ; load print
FSTRING_START       _                                       _               t47               ; f-string start
FSTRING_PART        '直接查詢：'                                 _               _                 ; literal: 直接查詢：
LOAD_NAME           student_a                               _               t48               ; load student_a
LOAD_ATTR           t48                                     name            t49               ; getattr name
FSTRING_PART        t49                                     _               _                 ; expr: t49
FSTRING_PART        ' 考了 '                                  _               _                 ; literal:  考了 
